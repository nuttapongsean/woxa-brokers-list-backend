# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# For local dev (npm run start:dev): DB_HOST=localhost
# For full Docker stack:            DB_HOST=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=woxa_user
DB_PASSWORD=change-me
DB_DATABASE=woxa_brokers
DB_SYNCHRONIZE=false

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters — generate with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-random-string-of-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-to-another-random-string-of-at-least-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_SECRET=change-this-to-a-random-string-of-at-least-32-chars

# ── Redis ─────────────────────────────────────────────────────────────────────
# For local dev (npm run start:dev): REDIS_HOST=localhost
# For full Docker stack:            REDIS_HOST=redis
REDIS_HOST=localhost
REDIS_PORT=6379

# ── S3 Storage ────────────────────────────────────────────────────────────────
# Railway S3-compatible storage — get credentials from Railway dashboard
S3_ENDPOINT=https://t3.storageapi.dev
S3_REGION=auto
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_PRESIGN_EXPIRES_IN=3600
