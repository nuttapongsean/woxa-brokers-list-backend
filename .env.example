# App
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=woxa_brokers
DB_SYNCHRONIZE=false

# JWT
JWT_SECRET=change-this-to-a-random-string-of-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-to-another-random-string-of-at-least-32-chars
JWT_REFRESH_EXPIRES_IN=1d

# Session
SESSION_SECRET=change-this-to-a-random-string-of-at-least-32-chars

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
