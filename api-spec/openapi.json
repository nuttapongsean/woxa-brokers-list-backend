    "/health": {
      "get": {
        "operationId": "HealthcheckController_check",
        "parameters": [],
        "responses": {
          "200": {
            "description": "The Health Check is successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    },
                    "info": {
                      "type": "object",
                      "example": {
                        "database": {
                          "status": "up"
                        }
                      },
                      "additionalProperties": {
                        "type": "object",
                        "required": [
                          "status"
                        ],
                        "properties": {
                          "status": {
                            "type": "string"
                          }
                        },
                        "additionalProperties": true
                      },
                      "nullable": true
                    },
                    "error": {
                      "type": "object",
                      "example": {},
                      "additionalProperties": {
                        "type": "object",
                        "required": [
                          "status"
                        ],
                        "properties": {
                          "status": {
                            "type": "string"
                          }
                        },
                        "additionalProperties": true
                      },
                      "nullable": true
                    },
                    "details": {
                      "type": "object",
                      "example": {
                        "database": {
                          "status": "up"
                        }
                      },
                      "additionalProperties": {
                        "type": "object",
                        "required": [
                          "status"
                        ],
                        "properties": {
                          "status": {
                            "type": "string"
                          }
                        },
                        "additionalProperties": true
                      }
                    }
                  }
                }
              }
            }
          },
          "503": {
            "description": "The Health Check is not successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "error"
                    },
                    "info": {
                      "type": "object",
                      "example": {
                        "database": {
                          "status": "up"
                        }
                      },
                      "additionalProperties": {
                        "type": "object",
                        "required": [
                          "status"
                        ],
                        "properties": {
                          "status": {
                            "type": "string"
                          }
                        },
                        "additionalProperties": true
                      },
                      "nullable": true
                    },
                    "error": {
                      "type": "object",
                      "example": {
                        "redis": {
                          "status": "down",
                          "message": "Could not connect"
                        }
                      },
                      "additionalProperties": {
                        "type": "object",
                        "required": [
                          "status"
                        ],
                        "properties": {
                          "status": {
                            "type": "string"
                          }
                        },
                        "additionalProperties": true
                      },
                      "nullable": true
                    },
                    "details": {
                      "type": "object",
                      "example": {
                        "database": {
                          "status": "up"
                        },
                        "redis": {
                          "status": "down",
                          "message": "Could not connect"
                        }
                      },
                      "additionalProperties": {
                        "type": "object",
                        "required": [
                          "status"
                        ],
                        "properties": {
                          "status": {
                            "type": "string"
                          }
                        },
                        "additionalProperties": true
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Healthcheck"
        ]
      }
    }
  },
  "info": {
    "title": "Woxa Brokers List API",
    "description": "REST API for managing financial brokers",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "fullName": {
            "type": "string",
            "example": "John Doe"
          },
          "email": {
            "type": "string",
            "example": "john@example.com"
          },
          "password": {
            "type": "string",
            "example": "P@ssw0rd!",
            "minLength": 8
          },
          "agreeToTerms": {
            "type": "boolean",
            "example": true,
            "description": "Must be true to accept terms"
          }
        },
        "required": [
          "fullName",
          "email",
          "password",
          "agreeToTerms"
        ]
      },
      "AuthUserDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "fullName": {
            "type": "string"
          },
          "email": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "fullName",
          "email"
        ]
      },
      "AuthTokensDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          },
          "user": {
            "$ref": "#/components/schemas/AuthUserDto"
          }
        },
        "required": [
          "accessToken",
          "refreshToken",
          "user"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "john@example.com"
          },
          "password": {
            "type": "string",
            "example": "P@ssw0rd!"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "RefreshTokenDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string"
          }
        },
        "required": [
          "refreshToken"
        ]
      },
      "ForgotPasswordDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "john@example.com"
          }
        },
        "required": [
          "email"
        ]
      },
      "ResetPasswordDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "Token received via email (console log in dev)"
          },
          "newPassword": {
            "type": "string",
            "minLength": 8
          },
          "confirmPassword": {
            "type": "string",
            "minLength": 8
          }
        },
        "required": [
          "token",
          "newPassword",
          "confirmPassword"
        ]
      },
      "UserProfileDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "fullName": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "fullName",
          "email",
          "createdAt",
          "updatedAt"
        ]
      },
      "UpdateProfileDto": {
        "type": "object",
        "properties": {
          "fullName": {
            "type": "string",
            "example": "Jane Doe"
          }
        },
        "required": [
          "fullName"
        ]
      },
      "CreateBrokerFeatureDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Zero Commission"
          },
          "description": {
            "type": "string",
            "example": "Trade with zero commission on all instruments."
          },
          "sortOrder": {
            "type": "number",
            "example": 0,
            "default": 0
          }
        },
        "required": [
          "title",
          "description"
        ]
      },
      "CreateBrokerMetricsDto": {
        "type": "object",
        "properties": {
          "aumGrowthYoY": {
            "type": "string",
            "example": "+34.2%"
          },
          "liquidityAccess": {
            "type": "string",
            "example": "$18.4B"
          },
          "liquidityAccessSub": {
            "type": "string",
            "example": "Daily Average"
          },
          "clientRetention": {
            "type": "string",
            "example": "94.7%"
          },
          "clientRetentionPeriod": {
            "type": "string",
            "example": "12-month rolling"
          }
        }
      },
      "CreateBrokerMarketsDto": {
        "type": "object",
        "properties": {
          "forexPairs": {
            "type": "number",
            "example": 100
          },
          "indices": {
            "type": "number",
            "example": 20
          },
          "commodities": {
            "type": "number",
            "example": 15
          },
          "equities": {
            "type": "number",
            "example": 500
          },
          "sovereignBonds": {
            "type": "number",
            "example": 50
          },
          "cryptoEtps": {
            "type": "number",
            "example": 30
          }
        }
      },
      "CreateBrokerDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Exness"
          },
          "slug": {
            "type": "string",
            "example": "exness",
            "description": "Auto-generated from name if omitted"
          },
          "description": {
            "type": "string",
            "example": "A leading multi-asset broker."
          },
          "logoUrl": {
            "type": "string",
            "example": "https://cdn.example.com/logos/exness.png"
          },
          "website": {
            "type": "string",
            "example": "https://www.exness.com"
          },
          "brokerType": {
            "type": "string",
            "enum": [
              "cfd",
              "bond",
              "stock",
              "crypto"
            ],
            "example": "cfd"
          },
          "imageUrl": {
            "type": "string",
            "example": "https://cdn.example.com/images/exness-cover.png"
          },
          "badge": {
            "type": "string",
            "example": "Premium TIER"
          },
          "tag": {
            "type": "string",
            "example": "SEC Regulated"
          },
          "icon": {
            "type": "string",
            "example": "shield"
          },
          "grade": {
            "type": "string",
            "example": "SOVEREIGN GRADE A+"
          },
          "rating": {
            "type": "number",
            "example": 5,
            "minimum": 1,
            "maximum": 5
          },
          "prospectusUrl": {
            "type": "string",
            "example": "https://cdn.example.com/docs/prospectus.pdf"
          },
          "longDescription": {
            "type": "string",
            "example": "Exness is a global multi-asset broker..."
          },
          "contactAddress": {
            "type": "string",
            "example": "123 Finance Street, Bangkok, Thailand"
          },
          "contactEmail": {
            "type": "string",
            "example": "support@exness.com"
          },
          "features": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateBrokerFeatureDto"
            }
          },
          "metrics": {
            "$ref": "#/components/schemas/CreateBrokerMetricsDto"
          },
          "markets": {
            "$ref": "#/components/schemas/CreateBrokerMarketsDto"
          }
        },
        "required": [
          "name",
          "description",
          "logoUrl",
          "website",
          "brokerType"
        ]
      },
      "UpdateBrokerDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Exness"
